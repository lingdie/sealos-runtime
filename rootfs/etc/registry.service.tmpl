[Unit]
Description=registry: The sealos registry
Documentation=https://github.com/distribution/distribution

[Service]
ExecStart={{ default "/usr/bin" .BIN_DIR }}/registry serve {{ .registryConfig }}/registry_config.yml
Restart=always
StartLimitInterval=0
RestartSec=10
LimitNOFILE=1048576
LimitNPROC=infinity
LimitCORE=infinity
LimitNOFILE=1048576
TasksMax=infinity

[Install]
WantedBy=multi-user.target
